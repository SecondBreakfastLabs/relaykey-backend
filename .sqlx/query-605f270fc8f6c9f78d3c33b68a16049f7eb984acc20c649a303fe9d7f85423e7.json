{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id, \n            virtual_key_id,\n            partner_name,\n            path,\n            request_hash,\n            status\n        FROM payment_intents\n        WHERE virtual_key_id = $1\n          AND partner_name = $2\n          AND path = $3\n          AND request_hash = $4\n          AND status = 'pending'\n        ORDER BY ts DESC\n        LIMIT 1\n        ",
